/* write a program which can help to calculate the Simple Interest with principal amount by the given information */

# include <stdio.h>

int main () {
    float principal,rate,time,interest;

    printf("enter the principal amount : \n ");
    scanf("%f", &principal );

    printf("enter the rate of interest : \n ");
    scanf("%f", &rate );

    printf("enter the time for principal return with intarest : \n ");
    scanf("%f", &time );

    interest = (principal * rate * time) / 100;
    
    printf("the interest will be : %f", interest);
    printf("the final amount will be : %f", interest + principal);
    

    return 0;
}
