/* write a program which can help to define the evne or odd which is given by user */

# include <stdio.h>
# include <math.h>

int main () {
     
    int a;
    
    printf("enter the number a : ");
    scanf("%d", &a);

    if (a % 2 == 0) {
        printf("the number is even ");
    }
    else {
        printf("the value is odd");
    }
    
    return 0;
}
