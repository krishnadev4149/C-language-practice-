// copying array logic
#include <stdio.h>
#include <math.h>

int n,i=0,a[10],b[10];

int main() {
printf("enter the length of arrey : ");
scanf("%d", &n);

for (i=0;i<n;i++) 
{
    printf("\nenter the %d element of arrey : ", i+1);
    scanf("%d", &a[i]);
}
for (i=0;i<n;i++) 
{
    b[i]=a[i];
}

printf("copy arrey is :\n");

for (i=0;i<n;i++) 
{
    printf("%d \n", b[i]);
}
    return 0;
}
