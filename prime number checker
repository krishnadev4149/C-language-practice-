#include <stdio.h>

int main() {
    int num;

    printf("Enter the number: ");
    scanf("%d", &num);

    if (num <= 1) {
        printf("Not prime");
        return 0;
    }

    for (int i = 2; i < num; i++) {
        if (num % i == 0) {
            printf("Not prime");
            return 0;
        }
    }

    printf("Prime number");

    return 0;
}
