/* write a program which can help to determine the type of real number which is given by the user */

# include <stdio.h>
# include <math.h>

int main () {
     
    int a;
    
    printf("enter the number a : ");
    scanf("%d", &a);

    if (a == 0) {
        printf(" a is equal to 0 ");
    }
    else if (a > 0) {
        printf("a is positive ");
    }
    else {
        printf(" a is negative ");
    }

    return 0;
}
